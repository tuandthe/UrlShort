# Database config (Supabase/PostgreSQL)
DB_URL=jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_MAX_POOL_SIZE=3
DB_MIN_IDLE=0
DB_CONNECTION_TIMEOUT_MS=30000
DB_MAX_LIFETIME_MS=300000
DB_IDLE_TIMEOUT_MS=120000
DB_FLYWAY_CONNECT_RETRIES=8

# Redis config
REDIS_PASSWORD=change_me_redis_password

# JWT
JWT_SECRET=change_me_jwt_secret_very_long_random
JWT_EXPIRATION_MS=120000 # 2 minutes
JWT_REFRESH_EXPIRATION_MS=604800000 # 7 days

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
APP_OAUTH2_REDIRECT_URI=http://localhost:3002/oauth2/callback

# MinIO config
MINIO_ROOT_USER=minio_admin_user
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=url-shortener
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=https://storage.urlshort.id.vn
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minio_admin_user
MINIO_SECRET_KEY=change_me_minio_password

# Mail
# Local Mailpit (dev):
# MAIL_HOST=mailpit
# MAIL_PORT=1025
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_SMTP_AUTH=false
# MAIL_SMTP_STARTTLS_ENABLE=false
# MAIL_SMTP_STARTTLS_REQUIRED=false

# Resend SMTP (real email):
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=587
# MAIL_USERNAME=resend
# MAIL_PASSWORD=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS_ENABLE=true
# MAIL_SMTP_STARTTLS_REQUIRED=true
# MAIL_SMTP_SSL_ENABLE=false
# MAIL_SMTP_SSL_TRUST=*
# MAIL_SMTP_CONNECTION_TIMEOUT=15000
# MAIL_SMTP_TIMEOUT=15000
# MAIL_SMTP_WRITE_TIMEOUT=15000
# MAIL_FROM=noreply@urlshort.io
# MAIL_FROM_NAME=UrlShort

# Resend SMTP (alternative implicit TLS):
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=465
# MAIL_USERNAME=resend
# MAIL_PASSWORD=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS_ENABLE=false
# MAIL_SMTP_STARTTLS_REQUIRED=false
# MAIL_SMTP_SSL_ENABLE=true
# MAIL_SMTP_SSL_TRUST=*
# MAIL_SMTP_CONNECTION_TIMEOUT=15000
# MAIL_SMTP_TIMEOUT=15000
# MAIL_SMTP_WRITE_TIMEOUT=15000
# MAIL_FROM=noreply@urlshort.io
# MAIL_FROM_NAME=UrlShort

MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false
MAIL_SMTP_STARTTLS_REQUIRED=false
MAIL_SMTP_SSL_ENABLE=false
MAIL_SMTP_SSL_TRUST=*
MAIL_SMTP_CONNECTION_TIMEOUT=15000
MAIL_SMTP_TIMEOUT=15000
MAIL_SMTP_WRITE_TIMEOUT=15000
MAIL_FROM=noreply@urlshort.io
MAIL_FROM_NAME=UrlShort

# Cloudflared Tunnel
CLOUDFLARED_TUNNEL_TOKEN=your_cloudflared_tunnel_token

# App settings
APP_BASE_URL=http://localhost:8080
APP_FRONTEND_URL=http://localhost:3002
APP_CORS_ALLOWED_ORIGINS=http://localhost:3002
